# Normalisation auto des fins de ligne
* text=auto

# Fichiers texte explicitement en LF
*.html text eol=lf
*.css  text eol=lf
*.js   text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.svg  text eol=lf
*.webmanifest text eol=lf

# Fichiers binaires (pas de conversion)
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.woff binary
*.woff2 binary
